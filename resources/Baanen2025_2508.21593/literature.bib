@Article{CommelinTopazAbstractionBoundaries,
  author     = {Commelin, Johan and Topaz, Adam},
  title      = {Abstraction boundaries and spec driven development in pure mathematics},
  journal    = {Bull. Amer. Math. Soc. (N.S.)},
  year       = {2024},
  volume     = {61},
  number     = {2},
  pages      = {241--255},
  issn       = {0273-0979,1088-9485},
  abstract   = {In this article we discuss how abstraction boundaries can help tame complexity in mathematical research with the help of an interactive theorem prover. While many of the ideas we present here have been used implicitly by mathematicians for some time, we argue that the use of an interactive theorem prover introduces additional qualitative benefits in the implementation of these ideas.},
  doi        = {10.1090/bull/1831},
  fjournal   = {American Mathematical Society. Bulletin. New Series},
  mrclass    = {68V30 (00A35 68V20)},
  mrnumber   = {4726990},
  mrreviewer = {Marco\ David},
  review     = {In this paper, the authors share key lessons learned from their formal computer verification of a recent, highly technical theorem in condensed mathematics. However, an understanding of the result is by no means necessary for this meta-discussion: Commelin and Topaz reflect known challenges in both the development and the communication of mathematics, in light of new possibilities enabled by the advances of computer proof assistants. Drawing analogies from industry standards in software development, such as specifications, they summarize general methods for verifying mathematics in collaboration with an interactive theorem prover (ITP). Examples from their formal verification effort in the Lean prover, dubbed the Liquid Tensor Experiment, illustrate the abstract discussion.
  The key suggestion of Commelin and Topaz is to work with a ``skeleton proof'', written in an ITP, where only definitions and key lemmas are stated, at first, and proofs are later filled in. In most ITPs, this is achieved through the keyword verb+sorry+ which has a dual use. On one hand, it temporarily axiomatizes unproven statements, to be applied in later proofs. On the other hand, it marks definitions as incomplete while already allowing the characterization of their intended behavior. The authors argue that this method, so-called abstraction boundaries, helps grapple with the increasing complexity of proofs in mathematics. Based on their experience, they especially put forward its advantages for collaborative efforts in formal verification and, prospectively, for the development of new mathematics.},
  url        = {https://doi.org/10.1090/bull/1831},
}

