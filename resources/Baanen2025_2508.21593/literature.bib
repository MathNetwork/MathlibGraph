@Article{RocqBot,
  author     = {Th{\'{e}}o Zimmermann and Julien Coolen and Jason Gross and Pierre{-}Marie P{\'{e}}drot and Ga{\"{e}}tan Gilbert},
  title      = {Extending the team with a project-specific bot},
  journal    = {CoRR},
