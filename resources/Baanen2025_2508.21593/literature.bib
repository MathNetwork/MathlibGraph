@Unpublished{PFRImproved,
  author   = {Jyun-Jie Liao},
  title    = {Improved Exponent for Marton's Conjecture in $F_2^n$},
  note     = {arXiv:2404.09639 [math.CO]},
  abstract = {A conjecture of Marton, widely known as the polynomial Freiman-Ruzsa conjecture, was recently proved by Gowers, Green, Manners and Tao for any bounded-torsion Abelian group $G$. In this paper we show a few simple modifications that improve their bound in $G=F_2^n$. Specifically, for $G=F_2^n$, they proved that any set $A\subseteq G$ with $|A+A|\le K|A|$ can be covered by at most $2K^C$ cosets of a subgroup $H$ of $G$ of cardinality at most $|A|$, with $C=12$. In this paper we prove the same statement for $C=9$. },
  url      = {https://arxiv.org/pdf/2404.09639.pdf},
}

@Unpublished{PFR2,
  author   = {W. T. Gowers and Ben Green and Freddie Manners and Terence Tao},
  title    = {Marton's Conjecture in abelian groups with bounded torsion},
  note     = {arXiv:2404.02244 [math.NT]},
  abstract = {We prove a Freiman--Ruzsa-type theorem with polynomial bounds in arbitrary abelian groups with bounded torsion, thereby proving (in full generality) a conjecture of Marton. Specifically, let $G$ be an abelian group of torsion $m$ (meaning $mg=0$ for all $g \in G$) and suppose that $A$ is a non-empty subset of $G$ with $|A+A| \leq K|A|$. Then $A$ can be covered by at most $(2K)^{O(m^3)}$ translates of a subgroup of $H \leq G$ of cardinality at most $|A|$. The argument is a variant of that used in the case $G = \mathbf{F}_2^n$ in a recent paper of the authors. },
  url      = {https://arxiv.org/pdf/2404.02244.pdf},
}

@Unpublished{PFR1,
  author   = {W. T. Gowers and Ben Green and Freddie Manners and Terence Tao},
  title    = {On a conjecture of Marton},
