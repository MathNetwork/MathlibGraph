\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2025/02/05 MathLibGraph paper preamble]

% ---------- encoding & fonts ----------
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% ---------- mathematics ----------
\RequirePackage{amsmath,amssymb,amsthm}

% ---------- layout ----------
\RequirePackage{geometry}
\geometry{margin=1in}
\emergencystretch=2em

% ---------- hyperlinks ----------
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=blue!70!black,
  citecolor=green!50!black,
  urlcolor=blue!70!black
}

% ---------- code highlighting ----------
\RequirePackage{xcolor}
\RequirePackage{minted}
\usemintedstyle{tango}

\newminted{lean4}{
  fontsize=\small,
  breaklines,
  frame=single,
  framesep=2mm,
  bgcolor=gray!5
}
\newcommand{\lean}[1]{\mintinline{lean4}{#1}}

% Allow line breaks at dots in identifiers
\ExplSyntaxOn
\tl_new:N \l__mfgraph_ident_tl
\cs_new_protected:Nn \__mfgraph_break_dots:n
  {
    \tl_set:Nn \l__mfgraph_ident_tl { #1 }
    \tl_replace_all:Nnn \l__mfgraph_ident_tl { . } { .\allowbreak }
    \tl_use:N \l__mfgraph_ident_tl
  }
\cs_set_eq:NN \identbreakdots \__mfgraph_break_dots:n
\ExplSyntaxOff
\newcommand{\module}[1]{\textcolor{blue!60!black}{\texttt{\identbreakdots{#1}}}}
\newcommand{\decl}[1]{\textcolor{red!70!black}{\texttt{\identbreakdots{#1}}}}
\newcommand{\ns}[1]{\textcolor{green!50!black}{\texttt{\identbreakdots{#1}}}}

% ---------- styled code boxes (§5-consistent coloring) ----------
\newsavebox{\codeboxsavebox}
\newenvironment{codebox}{%
  \begin{lrbox}{\codeboxsavebox}%
  \begin{minipage}{\dimexpr\linewidth-16pt}%
  \small\ttfamily\raggedright%
}{%
  \end{minipage}%
  \end{lrbox}%
  \par\smallskip\noindent
  {\setlength{\fboxsep}{6pt}\setlength{\fboxrule}{0.4pt}%
  \fcolorbox{black!30}{gray!5}{\usebox{\codeboxsavebox}}}%
  \par\smallskip
}

% ---------- tables ----------
\RequirePackage{booktabs}

% ---------- graphics & floats ----------
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{subcaption}

% ---------- diagrams ----------
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,positioning}
\RequirePackage[edges]{forest}

% ---------- finding boxes ----------
\newsavebox{\findingbox}
\newenvironment{finding}[1][]{%
  \begin{lrbox}{\findingbox}%
  \begin{minipage}{\dimexpr\linewidth-12pt}%
  \ifx&#1&\else{\bfseries #1}\par\smallskip\fi
}{%
  \end{minipage}%
  \end{lrbox}%
  \par\medskip\noindent
  \fcolorbox{blue!75!black}{blue!5!white}{%
    \usebox{\findingbox}%
  }%
  \par\medskip
}

% ---------- author comments ----------
\newcommand{\xinze}[1]{\textcolor{blue}{(\textbf{Comments}: #1)}}
\newcommand{\oliver}[1]{\textcolor{green!40!black}{(\textbf{Oliver}: #1)}}

% ---------- AI-collaboration margin bars (§5.1) ----------
\RequirePackage[breakable,skins]{tcolorbox}

% Three-color annotation system
\definecolor{colorHuman}{HTML}{2D5FA0}   % indigo – Human-led
\definecolor{colorAI}{HTML}{1A7A6E}      % teal   – AI + package
\definecolor{colorFree}{HTML}{8B5E3C}    % brown  – free-form description

% --- margin bar environments ---
\newenvironment{marginhuman}{%
  \begin{tcolorbox}[enhanced,breakable,
    borderline west={3pt}{0pt}{colorHuman},
    colback=white,colframe=white,
    fonttitle=\bfseries\color{colorHuman},title={Human-led},
    top=2pt,bottom=2pt,left=4pt,right=4pt,
    boxrule=0pt,sharp corners]}
  {\end{tcolorbox}}

\newenvironment{marginai}[1][]{%
  \begin{tcolorbox}[enhanced,breakable,
    borderline west={3pt}{0pt}{colorAI},
    colback=white,colframe=white,
    fonttitle=\bfseries\color{colorAI},title={AI\ifx&#1&\else{} + \texttt{#1}\fi},
    top=2pt,bottom=2pt,left=4pt,right=4pt,
    boxrule=0pt,sharp corners]}
  {\end{tcolorbox}}

\newenvironment{marginfree}[1][]{%
  \begin{tcolorbox}[enhanced,breakable,
    borderline west={3pt}{0pt}{colorFree},
    colback=white,colframe=white,
    fonttitle=\bfseries\color{colorFree},title={\ifx&#1&Free\else#1\fi},
    top=2pt,bottom=2pt,left=4pt,right=4pt,
    boxrule=0pt,sharp corners]}
  {\end{tcolorbox}}

% --- float annotation tag (for figure/table captions) ---
\newcommand{\aitag}[1][TikZ]{%
  \texorpdfstring{{\color{colorAI}\rule{3pt}{8pt}}\,{\small\bfseries\color{colorAI}AI + #1}\;\;}{[AI + #1] }%
}

% ---------- theorem environments ----------
\newtheorem{definition}{Definition}[subsection]
\newtheorem{proposition}[definition]{Proposition}
\newtheorem{corollary}[definition]{Corollary}
\newtheorem{property}[definition]{Property}
\newtheorem{example}[definition]{Example}
\newtheorem{remark}[definition]{Remark}
